{
  "launch": {
    "accelerate_config": "configs/accelerate_zero3.yaml",
    "gpu_devices": "0,1"
  },
  "paths": {
    "weights_dir": "weights/Wan2.2-TI2V-5B",
    "output_path": "model/train/tokenlight_pbr_shading_wan22_lora_zero3",
    "append_timestamp": true,
    "timestamp_format": "%Y%m%d_%H%M%S",
    "remove_prefix_in_ckpt": "pipe.dit."
  },
  "dataset": {
    "dataset_base_path": "data/objaverse_pbr_shading",
    "dataset_metadata_path": "data/objaverse_pbr_shading/metadata.jsonl",
    "data_file_keys": "video,input_image,pbr_image",
    "height": 640,
    "width": 640,
    "max_pixels": 409600,
    "num_frames": 1,
    "dataset_repeat": 1,
    "dataset_num_workers": 0,
    "batch_size": 5
  },
  "optimization": {
    "learning_rate": 0.0001,
    "num_epochs": 5,
    "weight_decay": 0.01,
    "gradient_accumulation_steps": 1,
    "save_steps": null,
    "customized_optimizer": null
  },
  "lora": {
    "trainable_models": null,
    "lora_base_model": "dit",
    "lora_target_modules": "q,k,v,o,ffn.0,ffn.2",
    "lora_rank": 32,
    "lora_checkpoint": null,
    "preset_lora_path": null,
    "preset_lora_model": null
  },
  "tokenlight": {
    "tokenlight_light_tokens": true,
    "tokenlight_source_tokens": true,
    "tokenlight_mask_tokens": false,
    "tokenlight_attrs_key": "attrs_json",
    "tokenlight_token_dim": 0,
    "tokenlight_fourier_features": 512,
    "tokenlight_fourier_sigma": 5.0,
    "tokenlight_max_lights": 2,
    "tokenlight_light_dropout": 0.0,
    "tokenlight_cfg_drop_prob": 0.1
  },
  "pbr": {
    "tokenlight_pbr_image_key": "pbr_image",
    "tokenlight_pbr_mode_key": "pbr_mode",
    "tokenlight_pbr_aux_type": "shading",
    "tokenlight_pbr_loss_weight": 1.0,
    "tokenlight_pbr_default_mode": "target",
    "balanced_task_batch": "single_light:2,double_light:2,ambient_only:1",
    "balanced_batch_seed": 0
  },
  "runtime": {
    "task": "sft",
    "use_gradient_checkpointing": true,
    "initialize_model_on_cpu": false,
    "framewise_decoding": false,
    "find_unused_parameters": false,
    "max_timestep_boundary": 1.0,
    "min_timestep_boundary": 0.0,
    "extra_inputs": null,
    "fp8_models": null,
    "offload_models": null
  },
  "logging": {
    "enable_tensorboard_log": true
  }
}
